# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis
REDIS_URL=redis://redis:6379

# Encryption (use a strong random secret in production)
ENCRYPTION_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars

# App URL (used for internal API calls from worker)
APP_URL=https://your-domain.com

# UazAPI
UAZAPI_DEFAULT_URL=https://free.uazapi.com
UAZAPI_ADMIN_TOKEN=your-uazapi-admin-token

# Optional: ElevenLabs for TTS
ELEVENLABS_API_KEY=

# Optional: OpenAI (used for embeddings generation at /api/embeddings)
OPENAI_API_KEY=
